        {
          "name": "Создать товар",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"socle_id\": 1,\n  \"shape_id\": 2,\n  \"type_id\": 1,\n  \"suppliers_id\": 3,\n  \"title\": \"Лампа светодиодная E27 10W\",\n  \"price\": 299.99,\n  \"quantity\": 100,\n  \"description\": \"Энергосберегающая светодиодная лампа\",\n  \"size\": 6.0,\n  \"illumination\": 800,\n  \"power\": 10,\n  \"awaited_delivery_time\": \"2026-05-01T00:00:00Z\",\n  \"is_visible\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/admin/goods",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "goods"]
            },
            "description": "Создаёт новый товар. По умолчанию is_visible=false — товар не виден в каталоге до публикации."
          },
          "response": []
        },
        {
          "name": "Обновить товар",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Лампа светодиодная E27 12W (обновлено)\",\n  \"price\": 349.99,\n  \"quantity\": 80,\n  \"description\": \"Обновлённое описание\",\n  \"size\": 6.5,\n  \"illumination\": 1000,\n  \"power\": 12,\n  \"awaited_delivery_time\": \"2026-06-01T00:00:00Z\",\n  \"is_visible\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/admin/goods/1",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "goods", "1"]
            },
            "description": "Полное обновление товара по ID."
          },
          "response": []
        },
        {
          "name": "Изменить видимость товара",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_visible\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/admin/goods/1/visibility",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "goods", "1", "visibility"]
            },
            "description": "Публикует или скрывает товар без полного обновления."
          },
          "response": []
        },
        {
          "name": "Удалить товар",
